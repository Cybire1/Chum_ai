# 0G testnet config for the Chum iNFT workspace. Copy to inft/.env and fill in.
# Use a DEDICATED 0G TESTNET key funded from the faucet — NOT your mainnet wallet.

ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_TESTNET_PRIVATE_KEY=0xYOUR_TESTNET_KEY
ZG_CHAIN_ID=16602
ZG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# Set after running scripts/deploy.ts
AGENT_NFT_ADDRESS=

# Optional: which wingman to mint (dry | goofy | smooth | nerdy)
CHUM_PERSONA=smooth
