{
  "expo": {
    "name": "Chum AI",
    "slug": "chum-ai",
    "scheme": "chum",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0A0C",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "xyz.chumai.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Use Face ID to lock Chum so only you can open your conversations.",
        "NSPhotoLibraryUsageDescription": "Chum reads the screenshots you pick on your device to draft replies. Screenshots never leave your phone."
      }
    },
    "android": {
      "package": "xyz.chumai.app",
      "predictiveBackGestureEnabled": false
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0A0C"
        }
      ]
    ]
  }
}
