# Chum — public app config. EXPO_PUBLIC_* is inlined into the bundle, so put
# ONLY non-secret values here (the publishable project key, not a server secret).

# huru relay base URL. Leave blank (or set EXPO_PUBLIC_MOCK=1) to run fully offline on mock replies.
EXPO_PUBLIC_HURU_BASE=https://your-huru-host.example.com

# huru publishable project key (identifies the project, not a user). NOT a server secret.
EXPO_PUBLIC_HURU_KEY=sk_test_huru_local_dev

# Force the local mock backend (no network). 1 = on. Defaults on when EXPO_PUBLIC_HURU_BASE is empty.
EXPO_PUBLIC_MOCK=1
